# Database
MONGODB_URI=mongodb://localhost:27017/clothstore

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars-long-here
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-long-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="ClothStore <noreply@clothstore.com>"

# Server
PORT=5000
CLIENT_URL=http://localhost:5173
NODE_ENV=development
